{
  "name": "mosaic-workspace",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "mobile",
    "server/admin-ui"
  ],
  "description": "Mosaic - Mobile (React Native) workspace",
  "scripts": {
    "mobile:start": "bun --filter @mosaic/mobile start",
    "mobile:android": "bun --filter @mosaic/mobile android",
    "mobile:ios": "bun --filter @mosaic/mobile ios",
    "mobile:web": "bun --filter @mosaic/mobile web",
    "build:sync": "bun --filter @mosaic/sync build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "check": "turbo run lint typecheck format:check",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/crayonlu/Mosaic.git"
  },
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0"
  },
  "devDependencies": {
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.14"
  }
}
