{
  "name": "@mosaic/api",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types/*": "./src/types/*"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.13.5"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "prettier": "^3.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
