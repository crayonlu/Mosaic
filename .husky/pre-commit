ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Ensure cargo is in PATH (macOS/Linux: ~/.cargo/bin)
export PATH="$HOME/.cargo/bin:$PATH"

echo "🎨 Auto-formatting code..."

# Format Rust (server)
if [ -f server/Cargo.toml ]; then
  (cd server && cargo fmt) || exit 1
  git add 'server/src/'
fi

# Format TypeScript via turbo (format:force bypasses stale cache)
bun run format:force || exit 1

# Re-stage formatted files so commit includes formatting changes
git add --update

echo "🔍 Running code checks..."

# Check Rust (server)
if [ -f server/Cargo.toml ]; then
  (cd server && cargo check) || exit 1
fi

# Check TypeScript via turbo (check:force ensures real check, not cached replay)
bun run check:force || exit 1

echo "✅ All checks and formatting passed!"
